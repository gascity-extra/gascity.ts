{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "installation": {
    "version": "latest"
  },
  "cli": {
    "packageManager": "bun"
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": ["default", "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)", "!{projectRoot}/tsconfig.spec.json", "!{projectRoot}/vitest.config.[jt]s", "!{projectRoot}/.eslintrc.json", "!{projectRoot}/src/test-setup.[jt]s", "!{projectRoot}/test-setup.[jt]s"],
    "sharedGlobals": []
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production", "{workspaceRoot}/configs/**"]
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^production", "{workspaceRoot}/vitest.workspace.ts", "{workspaceRoot}/configs/**"]
    },
    "lint": {
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/biome.json", "{workspaceRoot}/configs/**"]
    },
    "release": {
      "dependsOn": ["build"]
    }
  },
  "release": {
    "projects": [
      "@gascity/client",
      "@gascity/sdk"
    ],
    "projectsRelationship": "independent",
    "version": {
      "conventionalCommits": true,
      "fallbackCurrentVersionResolver": "disk"
    },
    "changelog": {
      "workspaceChangelog": true,
      "createRelease": "github",
      "gitTagPattern": "{version}",
      "gitRemote": "origin",
      "automaticFromRef": true
    },
    "git": {
      "commit": true,
      "tag": true
    },
    "npm": {
      "publish": true,
      "packageManager": "npm"
    }
  },
  "plugins": [
    "@nx/js"
  ],
  "workspaceLayout": {
    "appsDir": "packages",
    "libsDir": "packages"
  },
  "analytics": false
}
