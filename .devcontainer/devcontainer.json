{
  "name": "gascity.ts",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "forwardPorts": [8080, 8372],
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "upgradePackages": true
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24",
      "installGlibc": true
    },
    "ghcr.io/devcontainers/features/bun:1": {},
    "./features/devin": {
      "version": "latest"
    },
    "./features/cursor": {
      "version": "latest"
    },
    "./features/sacp-conductor": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "ms-vscode.vscode-typescript-next"
      ]
    }
  },
  "containerEnv": {
    "TERM": "xterm-256color"
  },
  "remoteUser": "vscode",
  "runArgs": ["--tty"],
  "postCreateCommand": "curl -fsSL https://bun.sh/install | bash && for rc in .bashrc .zshrc; do [ -f \"$HOME/$rc\" ] && (echo 'export BUN_INSTALL=\"$HOME/.bun\"' >> \"$HOME/$rc\" && echo 'export PATH=\"$BUN_INSTALL/bin:$PATH\"' >> \"$HOME/$rc\"); done || true"
}

