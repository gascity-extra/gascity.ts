{
  "name": "@gascity/client",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "description": "Type-safe Gas City API client generated from OpenAPI specification",
  "license": "MIT",
  "author": "Gas City Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/gascity-extra/gascity.git",
    "directory": "packages/@gascity/client"
  },
  "homepage": "https://github.com/gascity-extra/gascity#readme",
  "keywords": [
    "gascity",
    "api-client",
    "typescript",
    "openapi",
    "ai",
    "agent-orchestration"
  ],
  "bugs": {
    "url": "https://github.com/gascity-extra/gascity/issues"
  },
  "scripts": {
    "generate": "bun scripts/generate-openapi.ts",
    "build": "tsdown",
    "typecheck": "bunx tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "release": "nx release"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "axios": "^1.18.0",
    "form-data": "^4.0.6",
    "zod": "^3.25.76"
  }
}
