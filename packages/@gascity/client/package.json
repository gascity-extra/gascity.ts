{
  "name": "@gascity/client",
  "version": "1.0.0",
  "description": "Type-safe Gas City API client generated from OpenAPI specification",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "scripts": {
    "generate": "bun scripts/generate-openapi.ts",
    "build": "tsdown",
    "typecheck": "bunx tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "form-data": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "openapi-typescript-codegen": "^0.31.0",
    "@types/axios": "^0.14.0",
    "@types/node": "^22.0.0",
    "playwright": "^1.48.0",
    "vitest": "^4.1.0"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  }
}
