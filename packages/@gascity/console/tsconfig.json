{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "target": "ES2022",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/server/*": ["./server/*"]
    }
  },
  "include": ["src/**/*", "vite/**/*", "server/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "e2e", "test-results"]
}
